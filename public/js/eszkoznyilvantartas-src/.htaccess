# Ez a mappa a frontend FORRÁSA (src/, node_modules/, .env.production, stb.),
# nem a kiszolgált build. Ne legyen közvetlenül web-elérhető.
# A kiszolgált, bundle-ölt app a testvér ../eszkoznyilvantartas/ alatt van.
<IfModule mod_authz_core.c>
  Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
  Order deny,allow
  Deny from all
</IfModule>
